@@ -25,6 +25,32 @@ public static partial class EditorUtility
 			using CompileGroup compileGroup = new CompileGroup( "Publish" );
 			compileGroup.AccessControl = PackageManager.AccessControl;
 
+			// claude-sbox -- local engine modification. Skip the publish AccessControl
+			// whitelist for tool-type projects. The whitelist exists to restrict
+			// sandboxed game/library addons to a curated API surface (no Process,
+			// File I/O, HttpClient, raw editor types, etc.) -- correct for runtime-
+			// distributed content packages where end users may install untrusted
+			// code, but actively wrong for tool addons whose entire purpose is to
+			// extend the editor itself. The in-editor compile path (Project
+			// .Compiling.cs) doesn't apply this whitelist for ANY project type,
+			// which is why this addon (and any other tool addon) runs fine locally;
+			// the publish path here was the only place applying it. Result before
+			// this patch: ~700 "is not allowed when whitelist is enabled" errors
+			// per publish, against APIs the addon legitimately uses (PTY terminal
+			// via Process, FileSystem.Data via System.IO.File, HTTP MCP server via
+			// HttpListener / HttpClient, editor introspection via reflection, all
+			// the Editor.* widget types, ...).
+			//
+			// The published .cll content is identical to what the in-editor compile
+			// produces, just packaged for cloud distribution; loosening the publish
+			// whitelist for tools just brings parity with what the local compile
+			// already allows. Game/library publishes still get the standard
+			// whitelist enforcement.
+			if ( project.Config.Type == "tool" )
+			{
+				compileGroup.AccessControl = null;
+			}
