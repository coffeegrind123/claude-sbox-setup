+		// claude-sbox -- restored .cll (code-archive) compile fallback (removed upstream in #5038).
+		// Mounted on FileSystem at /.bin, this is where the freshly-compiled assemblies live.
+		MemoryFileSystem memoryFileSystem;
+
+		/// <summary>claude-sbox: does this package carry a code archive (.cll source) we could compile?</summary>
+		internal bool HasCodeArchives()
+		{
+			return FileSystem.FindFile( "/", "*.cll", true ).Any();
+		}
+
+		/// <summary>
+		/// claude-sbox: compile this package's code archive(s) (.cll = Roslyn source) into dll(s) and
+		/// mount them at /.bin, restoring the pre-#5038 client-side package compile. Returns false if
+		/// there's nothing to compile or the build fails.
+		/// </summary>
+		internal async Task<bool> CompileCodeArchive()
+		{
+			var codeArchives = FileSystem.FindFile( "/", "*.cll", true ).ToArray();
+			if ( codeArchives.Length == 0 )
+				return false;
+
+			using var group = new CompileGroup( Package.Ident );
+			group.AccessControl = PackageManager.AccessControl;
+			group.ReferenceProvider = this;
+
+			foreach ( var file in codeArchives )
+			{
+				var bytes = await FileSystem.ReadAllBytesAsync( file );
+				if ( bytes is null || bytes.Length <= 1 )
+					throw new System.Exception( $"[claude-sbox] couldn't read code archive '{file}'" );
+
+				var archive = new CodeArchive( bytes );
+				var compiler = group.GetOrCreateCompiler( archive.CompilerName );
+				compiler.UpdateFromArchive( archive );
+				LoadingScreen.Subtitle = System.IO.Path.GetFileName( file );
+				await Task.Yield();
+			}
+
+			LoadingScreen.Subtitle = null;
+			await group.BuildAsync();
+
+			if ( !group.BuildResult.Success )
+			{
+				Log.Warning( $"[claude-sbox] failed to compile code archive for {Package.FullIdent}:\n" +
+					group.BuildResult.BuildDiagnosticsString( Microsoft.CodeAnalysis.DiagnosticSeverity.Error ) );
+				return false;
+			}
+
+			memoryFileSystem = new MemoryFileSystem();
+			memoryFileSystem.CreateDirectory( "/.bin" );
+			foreach ( var assembly in group.BuildResult.Output )
+			{
+				memoryFileSystem.WriteAllBytes( $"/.bin/{assembly.Compiler.AssemblyName}.dll", assembly.AssemblyData );
+				LoadingScreen.Subtitle = assembly.Compiler.AssemblyName;
+				await Task.Yield();
+			}
+			FileSystem.Mount( memoryFileSystem );
+			LoadingScreen.Subtitle = null;
+			return true;
+		}
+
